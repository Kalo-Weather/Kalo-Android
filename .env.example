# Kalo Weather Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.

# Client secret for authenticating with the proxy server.
# Must differ from 'changeme_to_your_real_secret' for the proxy to work.
KALO_CLIENT_SECRET=changeme_to_your_real_secret

# Base URL of your proxy server (optional).
# If empty, defaults to https://kalo-vercel.vercel.app
KALO_PROXY_BASE_URL=https://kalo-vercel.vercel.app

# 64-character hex string (32 bytes) for AES-256-GCM key encryption.
# Must match the server's DECRYPTION_SECRET exactly.
# Leave empty if not using encrypted key transmission.
KALO_DECRYPTION_SECRET=
